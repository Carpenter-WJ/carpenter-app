node_modules/
firebase-debug.log

# 배포 predeploy 훅이 루트 pricing.js를 여기로 복사함 (배포 패키지가
# functions/ 폴더 밖은 못 가져가서) — 소스 아님, 매번 재생성됨
functions/pricing.js

# esbuild로 src/capacitor-bridge.js에서 빌드되는 산출물 — CI/로컬에서 재생성됨
/capacitor-bridge.js

# Capacitor webDir — sync-www.js가 루트 정적 파일에서 재생성함, 소스 아님
www/

# 네이티브 프로젝트 안의 웹 자산 복사본 — `npx cap sync` 때마다 재생성됨
android/app/src/main/assets/public/
ios/App/App/public/

# 릴리즈 서명 키스토어 — 절대 커밋 금지(분실 시 앱 업데이트 영구 불가)
android/keystore/
android/*.keystore
android/*.jks
android/key.properties

# Android 빌드 산출물
android/.gradle/
android/build/
android/app/build/
android/local.properties
android/.idea/
android/captures/

# iOS 빌드 산출물
ios/App/Pods/
ios/App/build/
ios/App/DerivedData/
ios/App/App.xcworkspace/xcuserdata/
ios/App/App.xcodeproj/xcuserdata/
ios/App/App.xcodeproj/project.xcworkspace/xcuserdata/
*.xcuserstate
