rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── 기존 개인(솔로) 데이터 — 변경 없음 ──
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /works/{workId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
      match /payments/{payId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // ── 초대 코드 조회용 최상위 컬렉션 ──
    match /inviteCodes/{code} {
      allow get: if request.auth != null;
      allow list: if false;
      allow create: if request.auth != null
        && isTeamLeader(request.resource.data.teamId, request.auth.uid);
      allow update: if request.auth != null
        && isTeamLeader(resource.data.teamId, request.auth.uid);
      allow delete: if false;
    }

    // ── 팀 ──
    match /teams/{teamId} {
      allow get: if request.auth != null;
      allow list: if isTeamMember(teamId, request.auth.uid);
      allow create: if request.auth != null
        && request.resource.data.leaderUid == request.auth.uid
        && request.resource.data.memberCount == 1;
      allow update: if isTeamLeader(teamId, request.auth.uid)
        || (
          request.auth != null
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount'])
          && request.resource.data.memberCount == resource.data.memberCount + 1
          && existsAfter(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
        );
      allow delete: if false;

      match /members/{memberUid} {
        allow get: if request.auth != null
          && (request.auth.uid == memberUid || isTeamMember(teamId, request.auth.uid));
        allow list: if isTeamMember(teamId, request.auth.uid);

        allow create: if request.auth != null && request.auth.uid == memberUid
          && (
            (request.resource.data.role == 'leader'
              && get(/databases/$(database)/documents/teams/$(teamId)).data.leaderUid == memberUid)
            ||
            (request.resource.data.role == 'member'
              && get(/databases/$(database)/documents/teams/$(teamId)).data.memberCount
                 < get(/databases/$(database)/documents/teams/$(teamId)).data.maxMembers)
          );

        allow update: if isTeamLeader(teamId, request.auth.uid);
        allow delete: if isTeamLeader(teamId, request.auth.uid);
      }

      // jobs = 현장 정보(주소/연락처/메모/공개범위 등)만 보관하는 공유 마스터 문서.
      // visibility: 'all'(전체) | 'selected'(지정 팀원) | 'private'(팀장만)
      match /jobs/{jobId} {
        // 팀장은 항상 조회. 팀원은 visibility에 따라 접근 범위 제한.
        allow read: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid)
              && (resource.data.get('visibility', 'all') == 'all'
                  || (resource.data.get('visibility', 'all') == 'selected'
                      && resource.data.get('sharedWith', []).hasAny([request.auth.uid]))));
        allow create: if isTeamMember(teamId, request.auth.uid)
          && request.resource.data.createdBy == request.auth.uid;
        // 현장 정보는 팀원 누구나 수정 가능(visibility/sharedWith 포함).
        allow update: if isTeamMember(teamId, request.auth.uid);
        allow delete: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid) && resource.data.createdBy == request.auth.uid);
      }

      // wages = 개인별 근무기록(날짜/품/일당).
      // ownerUid: 이 일당의 실제 주인. 팀장이 타인 대신 등록하면 ownerUid != createdBy.
      match /wages/{wageId} {
        allow read: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid)
              && resource.data.get('ownerUid', resource.data.createdBy) == request.auth.uid);
        // 팀원은 본인 것만, 팀장은 누구 것이든 ownerUid를 지정해 생성 가능.
        allow create: if isTeamMember(teamId, request.auth.uid)
          && request.resource.data.createdBy == request.auth.uid
          && (request.resource.data.ownerUid == request.auth.uid
              || isTeamLeader(teamId, request.auth.uid))
          && exists(/databases/$(database)/documents/teams/$(teamId)/jobs/$(request.resource.data.jobId));
        allow update, delete: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid)
              && resource.data.get('ownerUid', resource.data.createdBy) == request.auth.uid);
      }

      match /payments/{paymentId} {
        allow read: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid) && resource.data.createdBy == request.auth.uid);
        // createdBy는 해당 wages의 ownerUid와 일치해야 함.
        // 팀장이 팀원 대신 정산을 입력할 때도 createdBy = ownerUid(팀원uid)로 설정해야 규칙 통과.
        allow create: if isTeamMember(teamId, request.auth.uid)
          && request.resource.data.createdBy ==
             get(/databases/$(database)/documents/teams/$(teamId)/wages/$(request.resource.data.wageId)).data.ownerUid
          && (isTeamLeader(teamId, request.auth.uid) || request.auth.uid == request.resource.data.createdBy);
        allow update, delete: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid) && resource.data.createdBy == request.auth.uid);
      }

      // notifications = 팀장이 팀원 일당 등록/수정 시 생성하는 인앱 알림.
      match /notifications/{notifId} {
        // 팀원은 본인 앞으로 온 알림만 읽음. 팀장은 전체 조회 가능(발송 확인용).
        allow read: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid) && resource.data.toUid == request.auth.uid);
        // 알림 생성은 팀장만.
        allow create: if isTeamLeader(teamId, request.auth.uid)
          && request.resource.data.fromUid == request.auth.uid;
        // 팀원은 본인 알림 isRead 업데이트만 허용, 팀장은 모두.
        allow update: if isTeamLeader(teamId, request.auth.uid)
          || (isTeamMember(teamId, request.auth.uid)
              && resource.data.toUid == request.auth.uid
              && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']));
        allow delete: if isTeamLeader(teamId, request.auth.uid);
      }
    }

    function isTeamMember(teamId, uid) {
      return uid != null &&
        exists(/databases/$(database)/documents/teams/$(teamId)/members/$(uid));
    }
    function isTeamLeader(teamId, uid) {
      return uid != null &&
        get(/databases/$(database)/documents/teams/$(teamId)).data.leaderUid == uid;
    }
  }
}
