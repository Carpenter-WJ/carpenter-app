{
  "name": "hyunjangilji",
  "version": "1.0.0",
  "private": true,
  "description": "현장일지 — Capacitor 네이티브 래핑 프로젝트",
  "scripts": {
    "build:bridge": "esbuild src/capacitor-bridge.js --bundle --minify --format=iife --outfile=capacitor-bridge.js",
    "sync-www": "npm run build:bridge && node scripts/sync-www.js",
    "cap:sync": "npm run sync-www && npx cap sync",
    "cap:ios": "npm run cap:sync && npx cap open ios",
    "cap:android": "npm run cap:sync && npx cap open android"
  },
  "dependencies": {
    "@capacitor-firebase/authentication": "^7.5.0",
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.1.2",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/core": "^7.0.0",
    "@capacitor/filesystem": "^7.1.8",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/share": "^7.0.4",
    "@revenuecat/purchases-capacitor": "^11.3.2",
    "firebase": "^11.10.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "esbuild": "^0.28.1"
  }
}
